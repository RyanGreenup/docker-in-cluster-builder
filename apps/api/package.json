{
  "name": "@template/api",
  "version": "0.0.1",
  "private": true,
  "description": "oRPC API for the full-stack template",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch & tsx src/server.ts",
    "test": "vitest run tests --passWithNoTests",
    "check-types": "tsgo --skipLibCheck --noEmit",
    "format": "oxfmt . --write",
    "lint": "oxlint src --fix",
    "test:coverage": "vitest run tests --coverage",
    "check": "pnpm run check-types && pnpm run format && pnpm run lint && pnpm run test",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@orpc/server": "^1.14.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@template/oxlint-config": "workspace:*",
    "@types/node": "^25.9.3",
    "@typescript/native-preview": "^7.0.0-dev.20260614.1",
    "@vitest/coverage-v8": "4.1.7",
    "bumpp": "^11.1.0",
    "oxfmt": "^0.51.0",
    "oxlint": "1.61.0",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "4.1.7"
  }
}
