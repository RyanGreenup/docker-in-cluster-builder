{
  "name": "@rs/buildx-builder-cli",
  "version": "0.0.1",
  "private": true,
  "description": "Logic to build a docker image in-cluster",
  "license": "MIT",
  "author": "Ryan Greenup <ryanxgreenup@gmail.com>",
  "bin": {
    "buildx-builder-cli": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "cli": "pnpm run build && node ./dist/index.mjs",
    "test": "vitest run tests/index.test.ts",
    "test:e2e": "pnpm --dir ../lib run build && pnpm run build && vitest run tests/index.e2e.test.ts",
    "check-types": "tsgo --skipLibCheck --noEmit",
    "format": "oxfmt . --write",
    "lint": "oxlint src --fix",
    "check": "pnpm run check-types && pnpm run format && pnpm run lint && pnpm run test:e2e",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@rs/buildx-builder-lib": "workspace:*",
    "citty": "^0.2.2"
  },
  "devDependencies": {
    "@rs/oxlint-config": "workspace:*",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260524.1",
    "bumpp": "^11.1.0",
    "oxfmt": "^0.42.0",
    "oxlint": "1.61.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.7"
  }
}
