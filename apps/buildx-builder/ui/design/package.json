{
  "name": "@rs/ryan-personal-website-design",
  "version": "0.0.0",
  "private": false,
  "description": "Design tokens, sprinkles and global theme for Ryan's Personal Website; source-based, no build step",
  "homepage": "https://github.com/RyanGreenup/kubernetes-3#readme",
  "bugs": {
    "url": "https://github.com/RyanGreenup/kubernetes-3/issues"
  },
  "license": "MIT",
  "author": "Ryan Greenup <ryanxgreenup@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RyanGreenup/kubernetes-3.git"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.css.ts"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "@rs/source": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./sprinkles.css": {
      "@rs/source": "./src/sprinkles.css.ts",
      "types": "./src/sprinkles.css.ts",
      "import": "./src/sprinkles.css.ts",
      "default": "./src/sprinkles.css.ts"
    },
    "./palette": {
      "@rs/source": "./src/palette/index.ts",
      "types": "./src/palette/index.ts",
      "import": "./src/palette/index.ts",
      "default": "./src/palette/index.ts"
    },
    "./theme.css": {
      "@rs/source": "./src/theme.css.ts",
      "types": "./src/theme.css.ts",
      "import": "./src/theme.css.ts",
      "default": "./src/theme.css.ts"
    },
    "./recipes": {
      "@rs/source": "./src/recipes/index.ts",
      "types": "./src/recipes/index.ts",
      "import": "./src/recipes/index.ts",
      "default": "./src/recipes/index.ts"
    },
    "./global.css": "./src/global.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "check": "pnpm run check-types && pnpm run lint && pnpm run format",
    "check-types": "tsc --noEmit",
    "format": "oxfmt -c ./oxfmt.config.ts --check .",
    "format:write": "oxfmt -c ./oxfmt.config.ts .",
    "lint": "oxlint --type-aware --fix-suggestions -c ./oxlint.config.ts src"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@rs/layout": "workspace:*",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/sprinkles": "^1.6.5"
  },
  "devDependencies": {
    "@rs/oxlint-config": "workspace:*",
    "@rs/typescript-config": "workspace:*",
    "@types/node": "^25.9.1",
    "@vanilla-extract/css": "^1.20.1",
    "eslint-plugin-jsdoc": "^63.0.2",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
