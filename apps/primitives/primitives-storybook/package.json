{
  "name": "@rs/primitives-storybook",
  "version": "0.0.0",
  "private": true,
  "description": "Storybook for reusable @rs UI primitives.",
  "homepage": "https://github.com/RyanGreenup/kubernetes-3#readme",
  "bugs": {
    "url": "https://github.com/RyanGreenup/kubernetes-3/issues"
  },
  "license": "MIT",
  "author": "Ryan Greenup <ryanxgreenup@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RyanGreenup/kubernetes-3.git"
  },
  "type": "module",
  "scripts": {
    "check": "pnpm run check-types && pnpm run lint && pnpm run format && pnpm run test",
    "dev": "storybook dev -p 6008 --no-open",
    "storybook": "storybook dev -p 6008",
    "build": "storybook build",
    "build-storybook": "storybook build",
    "format": "oxfmt -c ./oxfmt.config.ts --check .",
    "format:write": "oxfmt -c ./oxfmt.config.ts .",
    "lint": "oxlint --fix-suggestions -c ./oxlint.config.ts src",
    "check-types": "tsc --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\""
  },
  "dependencies": {
    "@rs/layout": "workspace:*",
    "@rs/liatris-design": "workspace:*",
    "@rs/solid-primitives": "workspace:*",
    "@rs/storybook": "workspace:*",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@babel/standalone": "^7",
    "@fontsource/bricolage-grotesque": "^5.2.10",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10",
    "@fontsource/special-elite": "^5.2.8",
    "@fontsource/vt323": "^5.2.7",
    "@mdx-js/mdx": "^3",
    "@rs/oxlint-config": "workspace:*",
    "@rs/typescript-config": "workspace:*",
    "@storybook/addon-vitest": "^10.4.1",
    "@tanstack/solid-table": "^8.21.3",
    "@types/babel__standalone": "^7",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitest/browser-playwright": "4.1.7",
    "@zag-js/tree-view": "^1.41.2",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-turbo": "^2.9.17",
    "katex": "^0.16.22",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "^1.60.0",
    "solid-devtools": "^0.34.3",
    "storybook": "^10.4.1",
    "storybook-solidjs-vite": "^10.1.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "vite": "7.3.3",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "4.1.7"
  }
}
