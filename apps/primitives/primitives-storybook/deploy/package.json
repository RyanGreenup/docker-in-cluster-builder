{
  "name": "@rs/primitives-storybook-deploy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "true",
    "generate": "tsx src/generate.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "check-types": "tsc",
    "format": "oxfmt -c ./oxfmt.config.ts .",
    "fmt": "oxfmt -c ./oxfmt.config.ts .",
    "fmt:check": "oxfmt -c ./oxfmt.config.ts --check .",
    "lint": "oxlint -c ./oxlint.config.ts src",
    "lint:code": "pnpm run fmt && oxlint -c ./oxlint.config.ts --fix src"
  },
  "dependencies": {
    "@rs/k8s": "workspace:*",
    "js-yaml": "^4.1.0",
    "kubernetes-models": "^5.1.0"
  },
  "devDependencies": {
    "@rs/oxlint-config": "workspace:*",
    "@rs/typescript-config": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "oxlint-tsgolint": "^0.23.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
