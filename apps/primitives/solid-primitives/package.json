{
  "name": "@rs/solid-primitives",
  "version": "0.0.0",
  "private": false,
  "description": "Headless, theme-agnostic SolidJS UI primitives (Accordion, Calendar, Carousel, Dialog, DataTables, Virtualized) with optional skinned exemplars",
  "keywords": [
    "solid"
  ],
  "homepage": "https://github.com/RyanGreenup/kubernetes-3#readme",
  "bugs": {
    "url": "https://github.com/RyanGreenup/kubernetes-3/issues"
  },
  "license": "MIT",
  "author": "Ryan Greenup <ryanxgreenup@gmail.com>",
  "contributors": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RyanGreenup/kubernetes-3.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "browser": {},
  "types": "./dist/index.d.ts",
  "typesVersions": {},
  "exports": {
    ".": {
      "@rs/source": "./src/index.tsx",
      "types": "./dist/index.d.ts",
      "node": "./dist/server/index.js",
      "browser": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./exemplars": {
      "@rs/source": "./src/exemplars/index.tsx",
      "types": "./dist/exemplars/index.d.ts",
      "node": "./dist/server/exemplars/index.js",
      "browser": "./dist/exemplars/index.js",
      "import": "./dist/exemplars/index.js",
      "default": "./dist/exemplars/index.js"
    },
    "./ranger-theme": {
      "@rs/source": "./src/primitives/RangerModal/theme.ts",
      "types": "./src/primitives/RangerModal/theme.ts",
      "import": "./src/primitives/RangerModal/theme.ts",
      "default": "./src/primitives/RangerModal/theme.ts"
    },
    "./dist/*": "./dist/*"
  },
  "scripts": {
    "check": "pnpm run check-types && pnpm run lint && pnpm run format && pnpm run test",
    "dev": "vite serve dev",
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "test": "concurrently pnpm:test:*",
    "test:client": "vitest run",
    "test:ssr": "pnpm run test:client --mode ssr",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "prepublishOnly": "pnpm build",
    "format": "oxfmt -c ./.oxfmtrc.ts --check .",
    "format:write": "oxfmt -c ./.oxfmtrc.ts .",
    "lint": "oxlint --type-aware --fix-suggestions -c oxlint.config.ts src",
    "lint:types": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "update-deps": "pnpm up -Li"
  },
  "dependencies": {
    "@tanstack/solid-query": "^5.101.0",
    "@tanstack/solid-table": "^8.21.3",
    "@zag-js/solid": "^1.41.2",
    "@zag-js/tree-view": "^1.41.2",
    "corvu": "^0.7.2",
    "fuse.js": "^7.3.0"
  },
  "devDependencies": {
    "@babel/standalone": "^7",
    "@codemirror/commands": "^6",
    "@codemirror/lang-markdown": "^6",
    "@codemirror/language": "^6",
    "@codemirror/language-data": "^6",
    "@codemirror/state": "^6",
    "@codemirror/theme-one-dark": "^6",
    "@codemirror/view": "^6",
    "@mdx-js/mdx": "^3",
    "@replit/codemirror-vim": "^6",
    "@rs/oxlint-config": "workspace:*",
    "@rs/typescript-config": "workspace:*",
    "@tanstack/solid-virtual": "^3.13.25",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-code-block-lowlight": "^3.26.0",
    "@tiptap/extension-highlight": "^3.26.0",
    "@tiptap/extension-mathematics": "^3.26.0",
    "@tiptap/extension-placeholder": "^3.26.0",
    "@tiptap/extension-task-item": "^3.26.0",
    "@tiptap/extension-task-list": "^3.26.0",
    "@tiptap/extension-text-align": "^3.26.0",
    "@tiptap/extension-typography": "^3.26.0",
    "@tiptap/markdown": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@types/babel__standalone": "^7",
    "@types/node": "^25.9.1",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/rollup-plugin": "^1.5.3",
    "@vitest/browser": "4.1.7",
    "@vitest/browser-playwright": "4.1.7",
    "codemirror": "^6",
    "concurrently": "^8.2.2",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-turbo": "^2.9.17",
    "jsdom": "^24.0.0",
    "katex": "^0.16.22",
    "lowlight": "^3",
    "lucide-solid": "^1.17.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "^1.60.0",
    "rehype-katex": "^7",
    "remark-frontmatter": "^5",
    "remark-gfm": "^4",
    "remark-math": "^6",
    "solid-js": "^1.9.13",
    "solid-tiptap": "^0.8.0",
    "tsdown": "^0.22.0",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "vite": "7.3.3",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "4.1.7"
  },
  "peerDependencies": {
    "@babel/standalone": "^7",
    "@codemirror/commands": "^6",
    "@codemirror/lang-markdown": "^6",
    "@codemirror/language": "^6",
    "@codemirror/language-data": "^6",
    "@codemirror/state": "^6",
    "@codemirror/theme-one-dark": "^6",
    "@codemirror/view": "^6",
    "@mdx-js/mdx": "^3",
    "@replit/codemirror-vim": "^6",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-code-block-lowlight": "^3.26.0",
    "@tiptap/extension-highlight": "^3.26.0",
    "@tiptap/extension-mathematics": "^3.26.0",
    "@tiptap/extension-placeholder": "^3.26.0",
    "@tiptap/extension-task-item": "^3.26.0",
    "@tiptap/extension-task-list": "^3.26.0",
    "@tiptap/extension-text-align": "^3.26.0",
    "@tiptap/extension-typography": "^3.26.0",
    "@tiptap/markdown": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@vanilla-extract/recipes": "^0.5.7",
    "codemirror": "^6",
    "katex": "^0.16.22",
    "lowlight": "^3",
    "lucide-solid": "^1.17.0",
    "rehype-katex": "^7",
    "remark-frontmatter": "^5",
    "remark-gfm": "^4",
    "remark-math": "^6",
    "solid-js": "^1.9.13",
    "solid-tiptap": "^0.8.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9.0.0"
  }
}
