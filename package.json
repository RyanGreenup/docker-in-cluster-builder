{
  "name": "buildx-builder",
  "version": "0.0.1",
  "private": true,
  "description": "Logic to build a docker image in-cluster",
  "license": "MIT",
  "author": "Ryan Greenup <ryanxgreenup@gmail.com>",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:e2e": "pnpm --dir apps/buildx-builder/cli run test:e2e",
    "check-types": "turbo run check-types",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "check": "turbo run check"
  },
  "devDependencies": {
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "packageManager": "pnpm@10.33.2"
}
