{
  "name": "buildx-builder",
  "version": "0.0.1",
  "private": true,
  "description": "Logic to build a docker image in-cluster",
  "license": "MIT",
  "author": "Ryan Greenup <ryanxgreenup@gmail.com>",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:e2e": "pnpm --dir apps/buildx-builder/cli run test:e2e",
    "lint:deps": "sherif --ignore-rule packages-without-package-json --ignore-rule non-existant-packages && syncpack lint && taze -r",
    "check-types": "turbo run check-types",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "check": "turbo run check"
  },
  "devDependencies": {
    "sherif": "^1.11.1",
    "syncpack": "^15.3.1",
    "taze": "^19.9.2",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
