{
  "name": "buildx-builder",
  "version": "0.0.1",
  "private": true,
  "description": "Logic to build a docker image in-cluster",
  "license": "MIT",
  "author": "Ryan Greenup <ryanxgreenup@gmail.com>",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:e2e": "pnpm --dir apps/buildx-builder/cli run test:e2e",
    "lint:deps": "sherif -f  && syncpack fix && taze -r -w && pnpm install",
    "lint:deps:major": "sherif -f && syncpack lint && taze major -r -w && pnp install",
    "check-types": "turbo run check-types",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "check": "turbo run check"
  },
  "devDependencies": {
    "sherif": "^1.11.1",
    "syncpack": "^15.3.1",
    "taze": "^19.14.1",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.34.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
