{
  "name": "@rs/storybook",
  "version": "0.0.0",
  "description": "Shared Storybook framework configuration, helpers and Vitest setup.",
  "homepage": "https://github.com/RyanGreenup/kubernetes-3#readme",
  "bugs": {
    "url": "https://github.com/RyanGreenup/kubernetes-3/issues"
  },
  "license": "MIT",
  "author": "Ryan Greenup <ryanxgreenup@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RyanGreenup/kubernetes-3.git"
  },
  "files": [
    "src",
    ".storybook",
    "vite.shared.ts"
  ],
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    "./main": "./.storybook/main.shared.ts",
    "./preview": "./.storybook/preview.tsx",
    "./manager": "./.storybook/manager.ts",
    "./preview.css": "./.storybook/preview.css",
    "./vitest": "./vite.shared.ts",
    "./helpers": "./src/helpers/index.ts",
    "./playwright": "./src/playwright/index.ts",
    "./visual-parity-ids": "./src/helpers/visual-parity-ids.ts"
  },
  "scripts": {
    "check": "true",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "oxfmt -c ./oxfmt.config.ts .",
    "fmt": "oxfmt -c ./oxfmt.config.ts .",
    "fmt:check": "oxfmt -c ./oxfmt.config.ts --check .",
    "lint": "oxlint -c ./oxlint.config.ts src",
    "lint:code": "pnpm run fmt && oxlint -c ./oxlint.config.ts --fix src",
    "check-types": "tsc --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\""
  },
  "dependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@rs/storybook-solid-code-transform": "workspace:*",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/vite-plugin": "^5.2.2"
  },
  "devDependencies": {
    "@rs/oxlint-config": "workspace:*",
    "@rs/typescript-config": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-vitest": "^10.4.1",
    "@vitest/browser-playwright": "4.1.7",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "^1.60.0",
    "solid-devtools": "^0.34.3",
    "solid-js": "^1.9.13",
    "storybook": "^10.4.1",
    "storybook-solidjs-vite": "^10.1.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "vite": "7.3.3",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "4.1.7"
  },
  "peerDependencies": {
    "@playwright/test": "^1.60.0",
    "@storybook/addon-vitest": "^10.4.1",
    "@vitest/browser-playwright": "4.1.7",
    "playwright": "^1.60.0",
    "solid-devtools": "^0.34.3",
    "solid-js": "^1.9.13",
    "storybook": "^10.4.1",
    "storybook-solidjs-vite": "^10.1.0",
    "vite": "7.3.3",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "4.1.7"
  }
}
